{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/reports/:path*", "destination": "/api/reports" },
    { "source": "/api/report-groups/:path*", "destination": "/api/report-groups" },
    { "source": "/api/profiles/:path*", "destination": "/api/profiles" },
    { "source": "/api/users/:path*", "destination": "/api/users" },
    { "source": "/((?!api/|@)(?!.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}