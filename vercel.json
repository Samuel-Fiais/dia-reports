{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/reports/:path*", "destination": "/api/reports" },
    { "source": "/api/report-groups/:path*", "destination": "/api/report-groups" },
    { "source": "/api/profiles/:path*", "destination": "/api/profiles" },
    { "source": "/api/users/:path*", "destination": "/api/users" },
    { "source": "/api/shared/:path*", "destination": "/api/shared" },
    { "source": "/api/ai/:path*", "destination": "/api/ai" },
    { "source": "/api/slides/:path*", "destination": "/api/slides" },
    { "source": "/report/:slug", "destination": "/api/document?kind=report&slug=:slug" },
    { "source": "/shared/:token", "destination": "/api/document?kind=shared&token=:token" },
    { "source": "/((?!api/|@)(?!.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/document.js": {
      "includeFiles": "dist/index.html"
    }
  }
}